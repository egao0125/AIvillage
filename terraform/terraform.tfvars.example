# Copy this file: cp terraform.tfvars.example terraform.tfvars
# Fill in values, then: terraform init && terraform plan
#
# terraform.tfvars is gitignored.

aws_region  = "ap-northeast-1"
aws_profile = "ai-village-sso"   # SSO profile name from ~/.aws/config

cluster_name       = "ai-village"
kubernetes_version = "1.29"

# Check existing VPCs before deploying:
#   aws ec2 describe-vpcs --query 'Vpcs[*].CidrBlock' --profile ai-village-sso
# Change if 10.100.0.0/16 conflicts with an existing VPC.
vpc_cidr = "10.100.0.0/16"

node_instance_type = "t3.medium"
node_min_size      = 1
node_max_size      = 3
node_desired_size  = 2

redis_node_type = "cache.t3.micro"

# ---- Domain & HTTPS ----
# Terraform manages the Route53 hosted zone (dns.tf).
# Two options:
#   A) Register domain in AWS Console (Route53 → Registered domains) FIRST,
#      then: terraform import 'aws_route53_zone.app[0]' <ZONE_ID>
#   B) Set domain_name → terraform apply → note route53_nameservers output
#      → point your domain's NS records to those 4 nameservers at your registrar.
#
# domain_name  = "aivillage.example.com"   # your domain (Terraform creates the zone)
# alb_dns_name = ""                        # filled after first k8s deploy:
#                                          #   kubectl get ingress -n ai-village \
#                                          #     -o jsonpath='{.items[0].status.loadBalancer.ingress[0].hostname}'

# ---- EKS API access ----
eks_public_access_cidrs = ["YOUR_VPN_OR_OFFICE_CIDR/32"]
