# AI Village — Environment Configuration

# =============================================================================
# LLM API Key (BYOK — Bring Your Own Key)
# =============================================================================
# Provide at least one. Your key is used only for your agent's thinking.

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Default model to use (claude-sonnet-4-20250514, gpt-4o-mini, gemini-2.0-flash, etc.)
DEFAULT_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Server
# =============================================================================
PORT=4000
CLIENT_URL=http://localhost:3000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://localhost:5432/ai_village
REDIS_URL=redis://localhost:6379

# =============================================================================
# Simulation
# =============================================================================
# Tick rate in ms (how often the sim loop runs)
SIM_TICK_RATE=1000

# Max agents on the map
MAX_AGENTS=50
