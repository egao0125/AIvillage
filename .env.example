# AI Village — Environment Configuration

# =============================================================================
# LLM API Key (BYOK — Bring Your Own Key)
# =============================================================================
# Provide at least one. Your key is used only for your agent's thinking.

# Anthropic Claude
ANTHROPIC_API_KEY=

# Optional second Anthropic key for round-robin load balancing across agents.
# When set, even-indexed agents use KEY_1 and odd-indexed agents use KEY_2.
# Useful when a single key hits rate limits with many agents.
# Leave empty to use only ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY_2=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Default model (overridden by UI selection)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# Server
# =============================================================================
PORT=4000
CLIENT_URL=http://localhost:3000

# Redis connection URL.
# Required for multi-instance deployments (k8s / Fly.io with multiple machines).
# When unset, Socket.IO and rate limiting fall back to in-memory (single-instance only).
#
# Fly.io:   fly redis create  →  fly secrets set REDIS_URL=<url>
# Local:    docker run -p 6379:6379 redis:7-alpine
# Upstash:  https://upstash.com (serverless Redis, free tier available)
REDIS_URL=

# Comma-separated list of allowed CORS origins in production.
# Example: https://aivillage.com,https://www.aivillage.com
# Leave empty to reject all cross-origin requests.
ALLOWED_ORIGINS=

# Secret token required to use dev tools (pause/reset/fresh-start) via Socket.IO.
# Leave unset in production to disable dev commands entirely.
DEV_ADMIN_TOKEN=

# AES-256-GCM encryption key for API keys stored in the database.
# Required in production — without this, user API keys are stored as plaintext.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes).
ENCRYPTION_KEY=

# =============================================================================
# Supabase (persistence)
# =============================================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Simulation
# =============================================================================
# Tick rate in ms (how often the sim loop runs)
SIM_TICK_RATE=1000

# Max agents on the map
MAX_AGENTS=50
